            "source": [
                "# Exercise 1 \u2014 YOUR CODE",
                "# Use // so the answer is a whole number of groups",
                "students = 29",
                "group_size = 4",
                "full_groups = students / group_size",
                "print(\"Full groups: \" + str(full_groups))",
                ""
            ]
        },
