#!/usr/bin/env bash
set -euo pipefail

# Git LFS pre-push hook
command -v git-lfs >/dev/null 2>&1 || { printf >&2 "\n%s\n\n" "This repository is configured for Git LFS but 'git-lfs' was not found on your path. If you no longer wish to use Git LFS, remove this hook by deleting the 'pre-push' file in the hooks directory (set by 'core.hookspath'; usually '.git/hooks')."; exit 2; }
git lfs pre-push "$@"

# Sync construct template repositories (non-blocking — warns on failure)
repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"
echo "[pre-push] Syncing construct template repositories..."
uv run python scripts/sync_construct_template_repos.py || echo "[pre-push] Warning: template repo sync failed (see above)"
